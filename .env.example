# ─────────────────────────────────────────────────────────
# PetRadar — Variáveis de Ambiente
#
# Copie este arquivo para .env e preencha com valores reais.
# Consulte docs/setup-env.md para instruções detalhadas.
#
# NUNCA commite o arquivo .env — ele está no .gitignore.
# ─────────────────────────────────────────────────────────

# JWT — segredo de assinatura, mínimo 32 caracteres
JWT_SECRET=change-me-use-a-long-random-string-here

# MongoDB — credenciais do usuário root do container
MONGO_INITDB_ROOT_USERNAME=petradar_root
MONGO_INITDB_ROOT_PASSWORD=change-me-strong-password
MONGO_DB_NAME=petradar

# Redis — endereço do container Redis na rede interna do Docker
REDIS_CONNECTION_STRING=redis:6379

# ASP.NET Core — ambiente de execução
ASPNETCORE_ENVIRONMENT=Production

# JWT — expiração do token em minutos
JWT_EXPIRES_IN_MINUTES=60

# Media — caminho físico onde os arquivos de upload serão armazenados no container
MEDIA_BASE_PATH=/app/media

# CORS — origem do frontend acessada pelo navegador
FRONTEND_ORIGIN=http://localhost:5173
