{
  "info": {
    "_postman_id": "26f39b84-1b99-4b9e-9d17-51ea6c8ed70f",
    "name": "PetRadar - Animals Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var email = pm.collectionVariables.get('testEmail');",
              "if (!email) {",
              "  email = 'qa.animals.' + Date.now() + '@petradar.local';",
              "  pm.collectionVariables.set('testEmail', email);",
              "}",
              "",
              "var name = pm.collectionVariables.get('testName');",
              "if (!name) {",
              "  pm.collectionVariables.set('testName', 'QA Animals User');",
              "}",
              "",
              "var password = pm.collectionVariables.get('testPassword');",
              "if (!password) {",
              "  pm.collectionVariables.set('testPassword', 'Pass@123456');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"name\": \"{{testName}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        },
        "description": "Expected status: 201 Created"
      },
      "response": []
    },
    {
      "name": "Auth - Login (save token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "",
              "pm.test('response has token', function () {",
              "  pm.expect(json).to.have.property('data');",
              "  pm.expect(json.data).to.have.property('token');",
              "});",
              "",
              "if (json && json.data && json.data.token) {",
              "  pm.collectionVariables.set('authToken', json.data.token);",
              "}",
              "",
              "if (json && json.data && json.data.userId) {",
              "  pm.collectionVariables.set('loggedUserId', json.data.userId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Expected status: 200 OK and token at data.token"
      },
      "response": []
    },
    {
      "name": "Animals - Create Post (auth)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Golden retriever sem coleira visto perto da praca central\",\n  \"latitude\": -23.55052,\n  \"longitude\": -46.633308,\n  \"mediaIds\": []\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/animals",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "animals"
          ]
        },
        "description": "Expected status: 201 Created"
      },
      "response": []
    },
    {
      "name": "Animals - Nearby (save animal id + next token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var json = pm.response.json();",
              "pm.test('has paged envelope', function () {",
              "  pm.expect(json).to.have.property('data');",
              "  pm.expect(json).to.have.property('pagination');",
              "  pm.expect(json.pagination).to.have.property('nextPageToken');",
              "  pm.expect(json.pagination).to.have.property('hasNextPage');",
              "});",
              "",
              "if (json && json.pagination) {",
              "  pm.collectionVariables.set('nextPageToken', json.pagination.nextPageToken || '');",
              "}",
              "",
              "var items = (json && json.data) ? json.data : [];",
              "var loggedUserId = pm.collectionVariables.get('loggedUserId');",
              "var mine = items.find(function (x) {",
              "  return x && x.userId === loggedUserId && x.status === 'Lost';",
              "});",
              "",
              "if (mine && mine.id) {",
              "  pm.collectionVariables.set('animalPostId', mine.id);",
              "}",
              "",
              "pm.test('animalPostId was captured', function () {",
              "  var id = pm.collectionVariables.get('animalPostId');",
              "  pm.expect(id).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/animals/nearby?lat=-23.55052&lng=-46.633308&radius=10&pageSize=20&nextPageToken={{nextPageToken}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "animals",
            "nearby"
          ],
          "query": [
            {
              "key": "lat",
              "value": "-23.55052"
            },
            {
              "key": "lng",
              "value": "-46.633308"
            },
            {
              "key": "radius",
              "value": "10"
            },
            {
              "key": "pageSize",
              "value": "20"
            },
            {
              "key": "nextPageToken",
              "value": "{{nextPageToken}}"
            }
          ]
        },
        "description": "Expected status: 200 OK, paged response, and one item from logged user"
      },
      "response": []
    },
    {
      "name": "Animals - Mark As Found (auth)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 204', function () {",
              "  pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/animals/{{animalPostId}}/found",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "animals",
            "{{animalPostId}}",
            "found"
          ]
        },
        "description": "Expected status: 204 No Content"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7241"
    },
    {
      "key": "testEmail",
