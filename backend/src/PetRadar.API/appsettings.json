{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDB": {
    "ConnectionString": "mongodb://mongo:27017",
    "DatabaseName": "petradar"
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "PetRadar",
    "Audience": "PetRadar",
    "ExpiresInMinutes": 60
  },
  "Pagination": {
    "Cursor": {
      "DefaultPageSize": 20,
      "MaxPageSize": 100
    }
  },
  "LocalStorage": {
    "BasePath": "/app/media",
    "BaseUrl": "/media"
  },
  "MediaUpload": {
    "MaxFileSizeBytes": 5242880,
    "AllowedMimeTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
  }
}
