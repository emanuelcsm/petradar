{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "petradar"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Jwt": {
    "Secret": "dev-only-secret-key-must-be-at-least-32-chars!",
    "Issuer": "PetRadar",
    "Audience": "PetRadar",
    "ExpiresInMinutes": 1440
  },
  "Pagination": {
    "Cursor": {
      "DefaultPageSize": 20,
      "MaxPageSize": 100
    }
  },
  "LocalStorage": {
    "BasePath": "./media-dev",
    "BaseUrl": "/media"
  },
  "MediaUpload": {
    "MaxFileSizeBytes": 5242880,
    "AllowedMimeTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
  },
  "Cors": {
    "Frontend": {
      "AllowedOrigins": [
        "http://localhost:5173"
      ]
    }
  }
}
